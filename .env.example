# ── coSAFE Backend — Variables de entorno ─────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commits el archivo .env con valores reales al repositorio.

# Puerto del servidor Express (default: 3001)
PORT=3001

# Orígenes CORS permitidos (separados por coma, sin espacios)
# Desarrollo:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Producción (ajustar al dominio real):
# ALLOWED_ORIGINS=https://cosafeconsultoria.com

# ── Resend (envío de emails) ───────────────────────────────────────────────
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# Dirección remitente verificada en Resend
RESEND_FROM=cotizaciones@cosafeconsultoria.com

# Dirección de destino para las cotizaciones
RESEND_TO=administracion@cosafeconsultoria.com
